# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_CURRENCY=COP
DUNA_STORAGE_BACKEND=sheets
# Dashboard data target: runtime or demo
DASHBOARD_TARGET=runtime
# --- Database ---
# SQLAlchemy URL for live Postgres/Neon verification and future Postgres runtime use.
# Use postgresql+psycopg://... and prefer a direct/non-pooled Neon host for migrations.
DATABASE_URL=

# --- Twilio inbound webhook ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_PUBLIC_URL=
WEBHOOK_TENANT_ID=el-fogon-colombiano

# --- Twilio outbound pilot ---
# Disabled by default. Enable only for manual outbound smoke against a throwaway DB.
DUNA_OUTBOUND_ENABLED=false
DUNA_OUTBOUND_TENANT_ID=
TWILIO_WHATSAPP_FROM=
# --- LLM ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0

# --- Google Sheets ---
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/service_account.json

# Runtime spreadsheet used by Streamlit and scripts/seed_demo_catalog.py
GOOGLE_SHEETS_SPREADSHEET_ID=1WMrzP1W3W0GHeyDAt9Df6r18El-E_qJa3yx8A6urxh8

# Separate spreadsheet for live_sheets tests; must NOT equal the runtime ID
GOOGLE_SHEETS_TEST_SPREADSHEET_ID=
# Separate spreadsheet for generated demo data; must NOT equal the runtime ID
GOOGLE_SHEETS_DEMO_SPREADSHEET_ID=

ACTIVE_CLIENT_SHEET_ID=
ACTIVE_CLIENT_NAME=demo
